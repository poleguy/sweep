#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 package.deb"
    exit 1
fi

DEB_FILE="$(realpath "$1")"

if [[ ! -f "$DEB_FILE" ]]; then
    echo "File not found: $DEB_FILE"
    exit 1
fi

PKG_NAME="$(basename "$DEB_FILE")"

confirm_install() {
    if command -v zenity >/dev/null 2>&1; then
        zenity --question \
            --title="Install Package" \
            --width=400 \
            --text="Install package:\n\n$PKG_NAME\n\nThis will run:\nsudo apt install \"$DEB_FILE\""
    else
        echo "Install package: $PKG_NAME"
        read -rp "Proceed with installation? [y/N] " ans
        [[ "${ans,,}" == "y" || "${ans,,}" == "yes" ]]
    fi
}

if ! confirm_install; then
    exit 0
fi

# Pick a terminal emulator automatically
TERMINAL=""
for t in gnome-terminal konsole xfce4-terminal x-terminal-emulator xterm; do
    if command -v "$t" >/dev/null 2>&1; then
        TERMINAL="$t"
        break
    fi
done

if [[ -z "$TERMINAL" ]]; then
    echo "No terminal emulator found."
    exit 1
fi

CMD="echo Installing: '$DEB_FILE'; echo; sudo apt install '$DEB_FILE'; echo; read -p 'Press Enter to close...'"

case "$TERMINAL" in
    gnome-terminal)
        exec gnome-terminal -- bash -c "$CMD"
        ;;
    konsole)
        exec konsole -e bash -c "$CMD"
        ;;
    xfce4-terminal)
        exec xfce4-terminal --hold -e "bash -c \"$CMD\""
        ;;
    x-terminal-emulator)
        exec x-terminal-emulator -e bash -c "$CMD"
        ;;
    xterm)
        exec xterm -hold -e bash -c "$CMD"
        ;;
esac
